// Schema de banco de dados — Atomus Informática
// Rodar `npx prisma migrate dev` após configurar DATABASE_URL no .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENTE
}

enum ProjectStatus {
  ORCAMENTO
  APROVADO
  EM_DESENVOLVIMENTO
  EM_REVISAO
  CONCLUIDO
  CANCELADO
}

enum PaymentStatus {
  PENDENTE
  PROCESSANDO
  APROVADO
  RECUSADO
  ESTORNADO
}

enum PaymentMethod {
  PIX
  CARTAO
  BOLETO
}

enum PaymentProvider {
  MERCADO_PAGO
  STRIPE
  ASAAS
}

enum RequestStatus {
  ABERTA
  EM_ANDAMENTO
  RESPONDIDA
  ENCERRADA
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CLIENTE)

  cliente Client?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Client {
  id        String  @id @default(cuid())
  userId    String  @unique
  company   String?
  document  String? // CPF ou CNPJ
  phone     String?
  city      String?
  state     String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
  payments Payment[]
  contracts Contract[]
  requests  Request[]
  messages  Message[]
  files     File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Plan {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String
  features    String[]
  highlighted Boolean  @default(false)
  active      Boolean  @default(true)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  benefits    String[]
  avgDuration String
  icon        String?
  active      Boolean  @default(true)
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  planId      String?
  name        String
  description String?
  status      ProjectStatus @default(ORCAMENTO)
  progress    Int           @default(0)

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan     Plan?  @relation(fields: [planId], references: [id])
  payments Payment[]
  contracts Contract[]
  files     File[]
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model Contract {
  id        String   @id @default(cuid())
  clientId  String
  projectId String?
  title     String
  fileUrl   String?
  signedAt  DateTime?

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contracts")
}

model Payment {
  id             String          @id @default(cuid())
  clientId       String
  projectId      String?
  amount         Decimal         @db.Decimal(10, 2)
  method         PaymentMethod
  provider       PaymentProvider
  status         PaymentStatus   @default(PENDENTE)
  externalId     String? // ID da transação no gateway
  metadata       Json?

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Request {
  id        String        @id @default(cuid())
  clientId  String
  subject   String
  message   String
  status    RequestStatus @default(ABERTA)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("requests")
}

model Message {
  id        String   @id @default(cuid())
  clientId  String
  projectId String?
  sender    UserRole
  content   String

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  @@map("messages")
}

model File {
  id        String   @id @default(cuid())
  clientId  String
  projectId String?
  name      String
  url       String
  size      Int?
  mimeType  String?

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  @@map("files")
}

model PortfolioItem {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  category     String
  description  String
  technologies String[]
  imageUrl     String
  projectUrl   String?
  featured     Boolean  @default(false)
  order        Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolio_items")
}

model BlogPost {
  id         String    @id @default(cuid())
  slug       String    @unique
  title      String
  excerpt    String
  content    String
  coverImage String?
  category   String
  published  Boolean   @default(false)
  publishedAt DateTime?

  comments BlogComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

model BlogComment {
  id       String   @id @default(cuid())
  postId   String
  name     String
  email    String
  content  String
  approved Boolean  @default(false)

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("blog_comments")
}

model ContactMessage {
  id      String @id @default(cuid())
  name    String
  email   String
  phone   String?
  subject String?
  message String

  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
